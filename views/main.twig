{% extends "__layout.twig" %}
{% from "btn.twig" import btn%}
{% block content %}
<div style="display: flex; justify-content: space-around; flex-wrap: wrap;">
{% for object in synthesizers %}

    <div class="position-relative" style="margin-top: 25px; padding: 1%; display: flex; gap: 10px ;flex-direction:column; justify-content: space-between; align-items:center; border: 2px solid rgb(222, 222, 222); border-radius: 15px">
      
      <div class="position-absolute" style="right: 4px; top: 4px;">
        <form action="/synthesizers/delete" method="POST">
          <input type="hidden" name="id" value="{{object.id}}">
          <button type="submit" class="btn btn-danger">
            <i class="fas fa-times"></i>
          </button>
        </form>
      </div>

      <div class="position-absolute" style="right: 4px; top: 50px;">
        <form action="/synthesizers/{{object.id}}/edit">
          <input type="hidden" name="id" value="{{object.id}}">
          <button type="submit" class="btn btn-primary">
            <i class="fa-regular fa-pen-to-square"></i>
          </button>
        </form>
      </div>

      <div style="min-height: 140px; display: flex; justify-content: center; align-items: center">
        <div>
          <img style="max-width: 200px; height: auto;" src="{{object.image}}" alt="">
        </div>        
      </div>
      <div style="width: 100% ;">
          {{ btn(object.title, "/synthesizers/" ~ object.id , true)}}
          
        <div style="display: flex;">
          {{ btn("Картинка", "/synthesizers/" ~ object.id ~ "?show=image" , false)}}
          {{ btn("Описание","/synthesizers/" ~ object.id ~ "?show=info", false)}}
        </div>        
      </div>


    </div>
{% endfor %}
</div>
{% endblock %}